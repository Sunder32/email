# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/email_service
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/email_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_service

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# OpenRouter (GPT-4)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://email-service.tmsasub.ru"]
